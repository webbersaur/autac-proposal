{
  "cleanUrls": false,
  "trailingSlash": true,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "autacusa.com" }],
      "destination": "https://www.autacusa.com/$1",
      "permanent": true
    },

    { "source": "/coiled-extension-cords/", "destination": "/blog/coiled-extension-cords/", "permanent": true },
    { "source": "/retractile-power-cords-manufactured/", "destination": "/retractile-cords/", "permanent": true },
    { "source": "/women-of-excellence-luncheon/", "destination": "/news/women-of-excellence-luncheon/", "permanent": true },

    { "source": "/products/coiled-cords/", "destination": "/coiled-cords/", "permanent": true },
    { "source": "/products/curly-cords/", "destination": "/curly-cords/", "permanent": true },
    { "source": "/products/retractile-cords/", "destination": "/retractile-cords/", "permanent": true },
    { "source": "/products/cord-sets/", "destination": "/cord-sets/", "permanent": true },
    { "source": "/products/color-charts/", "destination": "/color-charts/", "permanent": true },
    { "source": "/autac-inc-products/", "destination": "/products/", "permanent": true },
    { "source": "/about-us/", "destination": "/about/", "permanent": true },
    { "source": "/news-press/", "destination": "/news/", "permanent": true },

    { "source": "/how-to-fix-retractable-cord-on-iron/", "destination": "/retractile-cords/", "permanent": true },
    { "source": "/how-to-fix-a-retractable-badge-reel/", "destination": "/retractile-cords/", "permanent": true },
    { "source": "/how-to-repair-a-retractable-badge-reel/", "destination": "/retractile-cords/", "permanent": true },
    { "source": "/understanding-vga-cable-cord/", "destination": "/cord-sets/", "permanent": true },
    { "source": "/straight-wiring-a-cooling-fan/", "destination": "/blog/", "permanent": true },
    { "source": "/tv-cables-cords-everything-you-need-to-know-for-the-best-home-entertainment-setup/", "destination": "/blog/", "permanent": true },
    { "source": "/how-to-hide-cable-cords-on-a-wall/", "destination": "/blog/", "permanent": true },

    {
      "source": "/:path((?!404|proposal-v1|invoice-deposit|admin).*).html",
      "destination": "/:path/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)\\.(png|jpg|jpeg|gif|svg|webp|ico)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.(css|js)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
